# Server
HOST=0.0.0.0
PORT=3000

# Transport: http (default, Streamable HTTP on /mcp) | stdio (stdin/stdout, for MCP clients)
# Can also be set via --stdio CLI flag which takes precedence.
MCP_TRANSPORT=http

# Storage backend: postgres | sqlite
# If STORAGE_BACKEND is unset, the runtime uses postgres when DATABASE_URL is set,
# otherwise it falls back to sqlite.
STORAGE_BACKEND=postgres

# PostgreSQL connection string. Required only when STORAGE_BACKEND=postgres.
# With docker compose, Postgres is published on host port 15432 (see compose.yml).
DATABASE_URL=postgres://coderag:coderag@localhost:15432/coderag

# SQLite file path. Used when STORAGE_BACKEND=sqlite.
SQLITE_PATH=./wend-rag.db

# Embedding provider: openai | voyage | openai-compatible
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_BASE_URL=http://localhost:11434/v1/
# OpenAI text-embedding-3-small uses 1536 dimensions by default.
# The shipped PostgreSQL migration aligns the schema to 1024 dimensions, and the
# SQLite backend stores 1024-dimensional embedding blobs as well.
# EMBEDDING_BASE_URL=https://api.voyageai.com
EMBEDDING_DIMENSIONS=1024

# Optional entity extraction and graph retrieval (works on both backends).
# Entity extraction calls an OpenAI-compatible chat completions endpoint and reuses
# EMBEDDING_API_KEY when ENTITY_EXTRACTION_API_KEY is unset.
# ENTITY_EXTRACTION_ENABLED=false
# GRAPH_RETRIEVAL_ENABLED=false
# GRAPH_TRAVERSAL_DEPTH=2
#
# Local — Ollama (no API key required):
# ENTITY_EXTRACTION_LLM_URL=http://localhost:11434
# ENTITY_EXTRACTION_LLM_MODEL=llama3.2
#
# OpenAI:
# ENTITY_EXTRACTION_LLM_URL=https://api.openai.com
# ENTITY_EXTRACTION_LLM_MODEL=gpt-4.1-mini
# ENTITY_EXTRACTION_API_KEY=sk-your-key-here
#
# Anthropic (OpenAI-compatible endpoint):
# ENTITY_EXTRACTION_LLM_URL=https://api.anthropic.com/v1
# ENTITY_EXTRACTION_LLM_MODEL=claude-haiku-4-5-20251001
# ENTITY_EXTRACTION_API_KEY=sk-ant-your-key-here

# Chunking strategy: fixed (default) | semantic
# "fixed" uses character-window overlap for oversized sections
# "semantic" uses embedding similarity to find topic boundaries
CHUNKING_STRATEGY=fixed
# Percentile threshold for semantic breakpoints (0.0-1.0, default 0.25)
# Lower = fewer breaks (larger chunks), higher = more breaks (smaller chunks)
# CHUNKING_SEMANTIC_THRESHOLD=0.25
